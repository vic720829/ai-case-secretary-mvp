rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/(default)/documents/users/$(request.auth.uid);
    }

    function projectPath(projectId) {
      return /databases/(default)/documents/projects/$(projectId);
    }

    function canReadProject(projectId) {
      // Storage Rules may read at most two Firestore documents per evaluation.
      // Read the user and project exactly once instead of exists() followed by get().
      let user = firestore.get(userPath()).data;
      let project = firestore.get(projectPath(projectId)).data;
      return signedIn() && projectId != "" && user.active != false && (
        user.role in ["owner", "admin", "manager"] ||
        ("memberUserIds" in project && request.auth.uid in project.memberUserIds)
      );
    }

    function canWriteProject(projectId) {
      let user = firestore.get(userPath()).data;
      let project = firestore.get(projectPath(projectId)).data;
      return signedIn() && projectId != "" && user.active != false &&
        user.role in ["owner", "admin", "manager", "staff"] && (
          user.role in ["owner", "admin", "manager"] ||
          ("memberUserIds" in project && request.auth.uid in project.memberUserIds)
        );
    }

    function canManageProjectFiles(projectId) {
      let user = firestore.get(userPath()).data;
      let project = firestore.get(projectPath(projectId)).data;
      return signedIn() && projectId != "" && user.active != false &&
        user.role in ["owner", "admin"] && project != null;
    }

    match /drawing-reviews/{projectId}/{reviewId}/source/{fileName} {
      allow read: if canReadProject(projectId);
      allow create, update: if canWriteProject(projectId) &&
        request.resource.size > 0 &&
        request.resource.size <= 50 * 1024 * 1024 &&
        request.resource.contentType == "application/pdf";
      allow delete: if canManageProjectFiles(projectId);
    }

    match /drawing-reviews/{projectId}/{reviewId}/report/{fileName} {
      allow read: if canReadProject(projectId);
      allow write: if false;
    }
  }
}
