rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return signedIn() && exists(userPath());
    }

    function userRole() {
      return hasUserProfile() ? get(userPath()).data.role : "";
    }

    function isActiveUser() {
      return hasUserProfile() && get(userPath()).data.active != false;
    }

    function hasAnyRole(roles) {
      return signedIn() && isActiveUser() && userRole() in roles;
    }

    function canWriteOps() {
      return hasAnyRole(["owner", "admin", "manager", "staff"]);
    }

    function canAccessAllProjects() {
      return hasAnyRole(["owner", "admin", "manager"]);
    }

    function canManageProjects() {
      return hasAnyRole(["owner", "admin", "manager"]);
    }

    function canManageUsers() {
      return hasAnyRole(["owner", "admin"]);
    }

    function canReadUserDirectory() {
      return hasAnyRole(["owner", "admin", "manager"]);
    }

    function isOwner() {
      return hasAnyRole(["owner"]);
    }

    function canManageSystemSettings() {
      return hasAnyRole(["owner", "admin"]);
    }

    function canManageFinance() {
      return hasAnyRole(["owner", "admin"]);
    }

    function projectPath(projectId) {
      return /databases/$(database)/documents/projects/$(projectId);
    }

    function projectExists(projectId) {
      return projectId is string && projectId != "" && exists(projectPath(projectId));
    }

    function isProjectMemberData(projectData) {
      return "memberUserIds" in projectData &&
        request.auth.uid in projectData.memberUserIds;
    }

    function canReadProjectData(projectData) {
      return signedIn() && isActiveUser() && (canAccessAllProjects() || isProjectMemberData(projectData));
    }

    function canReadProject(projectId) {
      return signedIn() && isActiveUser() && (
        canAccessAllProjects() ||
        (projectExists(projectId) && isProjectMemberData(get(projectPath(projectId)).data))
      );
    }

    function canWriteProjectLinkedData(projectId) {
      return canWriteOps() &&
        projectExists(projectId) &&
        canReadProjectData(get(projectPath(projectId)).data);
    }

    function canReadProjectManagementData() {
      return canAccessAllProjects();
    }

    match /users/{userId} {
      allow get: if signedIn() && (request.auth.uid == userId || canManageUsers());
      allow list: if canReadUserDirectory();
      allow create, update, delete: if canManageUsers();
    }

    match /projects/{projectId} {
      allow read: if canReadProjectData(resource.data);
      allow create, update, delete: if canManageProjects();
    }

    match /tasks/{taskId} {
      allow read: if canReadProject(resource.data.projectId);
      allow create: if canWriteProjectLinkedData(request.resource.data.projectId);
      allow update, delete: if canWriteProjectLinkedData(resource.data.projectId);
    }

    match /project_memos/{memoId} {
      allow read: if canReadProject(resource.data.projectId);
      allow create: if canWriteProjectLinkedData(request.resource.data.projectId);
      allow update, delete: if canWriteProjectLinkedData(resource.data.projectId);
    }

    match /project_memories/{memoryId} {
      allow read: if canReadProjectManagementData();
      allow create: if canAccessAllProjects() && canWriteProjectLinkedData(request.resource.data.projectId);
      allow update, delete: if canAccessAllProjects() && canWriteProjectLinkedData(resource.data.projectId);
    }

    match /project_summaries/{summaryId} {
      allow read: if canReadProjectManagementData();
      allow create: if canAccessAllProjects() && canWriteProjectLinkedData(request.resource.data.projectId);
      allow update, delete: if canAccessAllProjects() && canWriteProjectLinkedData(resource.data.projectId);
    }

    match /project_documents/{documentId} {
      allow read: if canReadProject(resource.data.projectId);
      allow create: if canWriteProjectLinkedData(request.resource.data.projectId);
      allow update, delete: if canWriteProjectLinkedData(resource.data.projectId);
    }

    match /drawing_reviews/{reviewId} {
      allow read: if canReadProject(resource.data.projectId);
      allow create: if canWriteProjectLinkedData(request.resource.data.projectId) &&
        request.resource.data.uploadedBy == request.auth.uid &&
        request.resource.data.status == "queued" &&
        request.resource.data.resultStatus == "pending" &&
        request.resource.data.ruleSetVersion == "company-v1.1" &&
        request.resource.data.projectSummaryStatus == "pending" &&
        request.resource.data.projectSummarySourceUpdatedAt == "" &&
        request.resource.data.projectRequirementChecks == [] &&
        request.resource.data.sourceContentType == "application/pdf" &&
        request.resource.data.sourceSizeBytes > 0 &&
        request.resource.data.sourceSizeBytes <= 50 * 1024 * 1024;
      allow update: if hasAnyRole(["owner", "admin", "manager"]) &&
        canReadProject(resource.data.projectId) &&
        request.resource.data.projectId == resource.data.projectId &&
        request.resource.data.sourceStoragePath == resource.data.sourceStoragePath &&
        request.resource.data.uploadedBy == resource.data.uploadedBy &&
        request.resource.data.ruleSetVersion == resource.data.ruleSetVersion &&
        request.resource.data.get("ruleSnapshot", []) == resource.data.get("ruleSnapshot", []) &&
        request.resource.data.get("projectSummaryStatus", "not_included") == resource.data.get("projectSummaryStatus", "not_included") &&
        request.resource.data.get("projectSummarySourceUpdatedAt", "") == resource.data.get("projectSummarySourceUpdatedAt", "") &&
        request.resource.data.get("projectRequirementChecks", []) == resource.data.get("projectRequirementChecks", []);
      allow delete: if canManageSystemSettings() && canReadProject(resource.data.projectId);
    }

    match /drawing_review_contexts/{reviewId} {
      allow read: if canReadProjectManagementData() && canReadProject(resource.data.projectId);
      allow create, update, delete: if false;
    }

    match /drawing_review_findings/{findingId} {
      allow read: if canReadProject(resource.data.projectId);
      allow create: if false;
      allow update: if hasAnyRole(["owner", "admin", "manager"]) &&
        canReadProject(resource.data.projectId) &&
        request.resource.data.projectId == resource.data.projectId &&
        request.resource.data.reviewId == resource.data.reviewId &&
        request.resource.data.ruleCode == resource.data.ruleCode &&
        request.resource.data.severity == resource.data.severity;
      allow delete: if canManageSystemSettings() && canReadProject(resource.data.projectId);
    }

    match /drawing_rule_sets/{ruleSetId} {
      allow read: if signedIn() && isActiveUser();
      allow create, update, delete: if isOwner();
    }

    match /drawing_rules/{ruleId} {
      allow read: if signedIn() && isActiveUser();
      allow create, update, delete: if isOwner();
    }

    match /projectStages/{stageId} {
      allow read: if canReadProject(resource.data.projectId);
      allow create: if canWriteProjectLinkedData(request.resource.data.projectId);
      allow update, delete: if canWriteProjectLinkedData(resource.data.projectId);
    }

    match /milestones/{milestoneId} {
      allow read: if canReadProject(resource.data.projectId);
      allow create: if canWriteProjectLinkedData(request.resource.data.projectId);
      allow update, delete: if canWriteProjectLinkedData(resource.data.projectId);
    }

    match /calendar_events/{eventId} {
      allow read: if canReadProject(resource.data.projectId);
      allow create: if canWriteProjectLinkedData(request.resource.data.projectId);
      allow update, delete: if canWriteProjectLinkedData(resource.data.projectId);
    }

    match /finance_project_settings/{settingsId} {
      allow read, create, update, delete: if canManageFinance();
    }

    match /finance_accounts/{accountId} {
      allow read, create, update, delete: if canManageFinance();
    }

    match /finance_payments/{paymentId} {
      allow read, create, update, delete: if canManageFinance();
    }

    match /finance_adjustments/{adjustmentId} {
      allow read, create, update, delete: if canManageFinance();
    }

    match /finance_costs/{costId} {
      allow read, create, update, delete: if canManageFinance();
    }

    match /finance_ledger/{ledgerId} {
      allow read, create, update, delete: if canManageFinance();
    }

    match /finance_drafts/{draftId} {
      allow read, create, update, delete: if canManageFinance();
    }

    match /line_groups/{lineGroupId} {
      allow read: if canManageSystemSettings();
      allow create, update, delete: if canManageSystemSettings();
    }

    match /line_pending_groups/{linePendingGroupId} {
      allow read: if canManageSystemSettings();
      allow create, update, delete: if canManageSystemSettings();
    }

    match /line_members/{lineMemberId} {
      allow read: if canManageSystemSettings();
      allow create, update, delete: if canManageSystemSettings();
    }

    match /messages/{messageId} {
      allow read: if canReadProjectManagementData();
      allow create: if canAccessAllProjects() && canWriteProjectLinkedData(request.resource.data.projectId);
      allow update, delete: if canAccessAllProjects() && canWriteProjectLinkedData(resource.data.projectId);
    }

    match /ai_tasks/{aiTaskId} {
      allow read: if canReadProjectManagementData();
      allow create: if canAccessAllProjects() && canWriteProjectLinkedData(request.resource.data.projectId);
      allow update, delete: if canAccessAllProjects() && canWriteProjectLinkedData(resource.data.projectId);
    }

    match /incidents/{incidentId} {
      allow read: if canReadProjectManagementData();
      allow create: if canAccessAllProjects() && canWriteProjectLinkedData(request.resource.data.projectId);
      allow update, delete: if canAccessAllProjects() && canWriteProjectLinkedData(resource.data.projectId);
    }

    match /reminder_logs/{reminderLogId} {
      allow read: if canReadProject(resource.data.projectId);
      allow create: if canWriteProjectLinkedData(request.resource.data.projectId);
      allow update, delete: if canWriteProjectLinkedData(resource.data.projectId);
    }

    match /webhook_logs/{webhookLogId} {
      allow read: if isOwner();
      allow create, update, delete: if canManageSystemSettings();
    }

    match /audit_logs/{auditLogId} {
      allow read: if isOwner();
      allow create: if canWriteOps();
      allow update, delete: if false;
    }

    match /ai_feedback_events/{eventId} {
      allow read: if isOwner();
      allow create: if canWriteOps();
      allow update, delete: if false;
    }

    match /learned_rules/{ruleId} {
      allow read, create, update, delete: if isOwner();
    }
  }
}
